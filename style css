/* Koko sivun taustalle asetetaan tiiliseinä */
body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100vh; /* Sivun vähimmäiskorkeus on koko ruutu */
    background-image: url("brick-wall.jpg");
    background-size: cover; /* Kuva täyttää koko taustan */
    background-position: center; /* Keskittää kuvan */
    background-repeat: no-repeat;
    background-attachment: fixed; /* Tausta pysyy paikallaan skrollatessa */
}


.hero-header {
    position: relative;
    width: 100%;
    height: 30vh;
    overflow: hidden;
}

.bg-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
}

.logo-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 2;
}

.logo-container img {
    max-width: 300px;
    width: 100%;
    height: auto;
    filter: drop-shadow(0px 4px 15px rgba(0, 0, 0, 0.7)); /* Tekee hienon varjon, logo erottuu vedestä */
}